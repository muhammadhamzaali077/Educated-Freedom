NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=file:./data/portal.db

# Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://127.0.0.1:3000

# Canva Connect API (Phase 9). Canva REJECTS `localhost` as a registered
# redirect URL — only `127.0.0.1` is accepted for local development. Browse
# the portal at http://127.0.0.1:3000 (NOT http://localhost:3000) so the
# OAuth callback URL matches byte-for-byte. Source:
# https://www.canva.dev/docs/connect/creating-integrations/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://127.0.0.1:3000/api/canva/callback

# Logging
LOG_LEVEL=info
